# Free LLM providers — generated from registry.yaml, do not edit by hand.
# Fill the keys you use, then `source` this file. Every endpoint is
# OpenAI-compatible: point any SDK/agent at the base URL next to the key.

# ── NVIDIA NIM (build.nvidia.com) — base: https://integrate.api.nvidia.com/v1 · get a key: https://build.nvidia.com
export NVIDIA_NIM_API_KEY=""

# ── OpenRouter (free models) — base: https://openrouter.ai/api/v1 · get a key: https://openrouter.ai/settings/keys
export OPENROUTER_API_KEY=""
#    note: pick models with the :free suffix

# ── DeepSeek Platform — base: https://api.deepseek.com · get a key: https://platform.deepseek.com/api_keys
export DEEPSEEK_API_KEY=""

# ── Groq — base: https://api.groq.com/openai/v1 · get a key: https://console.groq.com/keys
export GROQ_API_KEY=""

# ── Hugging Face Inference Providers — base: https://router.huggingface.co/v1 · get a key: https://huggingface.co/settings/tokens
export HUGGINGFACE_INFERENCE_API_KEY=""
#    note: chat-only; model ids namespaced (openai/gpt-oss-120b)

# ── Cerebras Inference — base: https://api.cerebras.ai/v1 · get a key: https://cloud.cerebras.ai
export CEREBRAS_API_KEY=""

# ── OVHcloud AI Endpoints — no key needed · base: https://oai.endpoints.kepler.ai.cloud.ovh.net/v1
#    note: anonymous, rate-limited; free key raises limits

# ── LongCat API Platform — base: https://api.longcat.chat/openai/v1 · get a key: https://longcat.chat/platform
export LONGCAT_API_KEY=""
#    note: Anthropic-compatible sibling at /anthropic/v1/messages; docs include a Claude Code setup guide (cc-switch)

# ── Cloudflare Workers AI — base: https://api.cloudflare.com/client/v4/accounts/{account_id}/ai/v1 · get a key: https://dash.cloudflare.com/profile/api-tokens
export CLOUDFLARE_WORKERS_AI_API_KEY=""
#    note: substitute {account_id} with your Cloudflare account ID

# ── Ollama Cloud — base: https://ollama.com/v1 · get a key: https://ollama.com/settings/keys
export OLLAMA_CLOUD_API_KEY=""
#    note: Free-tier model set verified live 2026-07-20; /v1/models lists the full catalog including subscription-only models

# ── Upstage (Solar API) — base: https://api.upstage.ai/v1 · get a key: https://console.upstage.ai/api-keys
export UPSTAGE_API_KEY=""

# ── Mistral La Plateforme — base: https://api.mistral.ai/v1 · get a key: https://console.mistral.ai/api-keys
export MISTRAL_API_KEY=""
#    note: Experiment tier needs account activation

# ── Reka AI — base: https://api.reka.ai/v1 · get a key: https://platform.reka.ai
export REKA_API_KEY=""
#    note: OpenAI-style chat completions; research and vision endpoints go beyond the OpenAI schema

# ── Pollinations.AI — no key needed · base: https://text.pollinations.ai/openai
#    note: anonymous works; optional token raises rate limits

# ── Alibaba Cloud Model Studio (DashScope, international) — base: https://dashscope-intl.aliyuncs.com/compatible-mode/v1 · get a key: https://modelstudio.console.alibabacloud.com
export ALIBABA_MODEL_STUDIO_API_KEY=""
